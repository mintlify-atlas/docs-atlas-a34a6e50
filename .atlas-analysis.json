    "POST /api/get-messages - Retrieve chat message history",
    "POST /api/stripe - Handle Stripe checkout sessions",
    "POST /api/webhook - Process Stripe webhook events",
    "uploadToS3(file) - Upload PDF files to AWS S3",
    "getS3Url(fileKey) - Generate S3 file URLs",
    "loadS3IntoPinecone(fileKey) - Process and vectorize PDF content",
    "getEmbeddings(text) - Generate text embeddings via OpenAI",
    "getContext(query, fileKey) - Retrieve relevant PDF context for queries",
